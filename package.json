{
  "name": "rate-limiter",
  "version": "1.0.0",
  "private": true,
  "description": "An external rate-limiter service built to practice and explore different system design techniques.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "eslint": "npx eslint .",
    "eslint-fix": "npx eslint . --fix",
    "test": "npx vitest run test .",
    "cc": "npm run build && npm run eslint-fix && npm run eslint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "redis": "^5.12.1"
  }
}
